MONGO_URI=mongodb://localhost:27017
MONGO_DB=healthcare_ehr
MONGO_COLLECTION=raw_patient_visits
SIMULATOR_INTERVAL_SECONDS=60
SIMULATOR_BATCH_SIZE=5
SIMULATOR_RANDOM_SEED=42
HOSPITAL_ID=HOSP_001
EHR_TEMPLATE_CSV=Data/EHR_FInal.csv
SYNTHETIC_OUTPUT_CSV=Data/synthetic_ehr.csv
SIMULATOR_SINK=both
AIRBYTE_STAGING_CONFIG=config/airbyte_staging_config.json
AIRBYTE_SOURCE_CSV=Data/EHR_FInal.csv
BRONZE_TO_SILVER_CONFIG=config/bronze_to_silver_config.json
SILVER_TO_GOLD_CONFIG=config/silver_to_gold_config.json
GOLD_TO_SQL_CONFIG=config/gold_to_sql_config.json
FINAL_OUTPUT_CONFIG=config/final_output_config.json

# Airflow scheduler controls for real hospital-like micro-batches.
# Every 15 minutes by default; examples: */5 * * * * or 0 * * * *
PIPELINE_SCHEDULE_CRON=*/15 * * * *
PIPELINE_MAX_ACTIVE_RUNS=1

# Toggle simulated feed generation before ingestion.
PIPELINE_SIMULATOR_ENABLED=true
PIPELINE_SIMULATOR_BATCH_SIZE=200
PIPELINE_SIMULATOR_SINK=csv

GOLD_DB_USER=airflow
GOLD_DB_PASSWORD=airflow
GOLD_DB_HOST=localhost
GOLD_DB_PORT=5432
GOLD_DB_NAME=airflow
# Optional full override:
# GOLD_SQLALCHEMY_URL=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
